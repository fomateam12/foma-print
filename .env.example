# FomaPrint environment variables
# Copy to `.env.local` and fill in. All values are optional for local dev:
# without RESEND_API_KEY the contact/order emails are skipped (logged, no-op),
# so the forms still succeed end-to-end while you build.

# Resend API key for transactional email (https://resend.com/api-keys).
# When unset, order/application emails are skipped instead of sent.
RESEND_API_KEY=

# From address for outgoing email. Must be a Resend-verified domain in prod.
# Defaults to "FomaPrint <onboarding@resend.dev>" (Resend's shared test sender).
EMAIL_FROM="FomaPrint <orders@yourdomain.com>"

# Where custom-order and reseller-application notifications are delivered.
# Defaults to the brand inbox (fomafamilydesign@gmail.com) when unset.
EMAIL_TO=fomafamilydesign@gmail.com

# Public canonical site URL — used for metadata, sitemap, robots and OG tags.
# Set to your production domain on deploy.
NEXT_PUBLIC_SITE_URL=https://foma-design.vercel.app
